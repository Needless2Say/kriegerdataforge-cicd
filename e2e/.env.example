# Tier 2 E2E configuration. Copy to `.env` (gitignored) and fill in.
# The suite reads these via the environment; playwright.config.ts + the specs
# fall back to the localhost defaults below when unset.

# Fitness frontend (system-under-test entry point)
E2E_BASE_URL=http://localhost:3000

# Hub hosted auth-UI (login + consent), the OIDC issuer origin
E2E_AUTH_UI_URL=http://localhost:3002

# A seeded, ACTIVE hub user to log in as. Create one against the running stack:
#   docker exec kdf-api python -c "from api.auth.service import AuthDatabaseService; \
#     from api.auth.schemas import RegisterRequest; \
#     AuthDatabaseService().create_user(RegisterRequest(username='e2e-user', \
#     password='E2eTest123!', email='e2e-user@example.com'), auto_activate=True)"
E2E_USERNAME=e2e-user
E2E_PASSWORD=E2eTest123!

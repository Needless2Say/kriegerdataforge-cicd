# Copy this file to .env.backup and fill in real values.
# NEVER commit .env.backup — it is in .gitignore.

# psycopg2-style connection URL for the target database.
# Find it in: Neon Dashboard → your project → Connection Details → Connection string
# Switch the Neon branch to "main" for prod, "dev" for dev.
#
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DB_BACKUP_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/tiffanys_space?sslmode=require

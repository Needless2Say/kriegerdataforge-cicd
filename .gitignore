# ── Python ─────────────────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/

# ── Virtual environments ────────────────────────────────────────────────────────
**/venv/
**/.venv/

# ── Secrets / local env files ───────────────────────────────────────────────────
# Real credentials used by the backup/rotation scripts — never commit.
# A leading-slash-free `.env*` matches at EVERY level, so this covers both
# scripts/.env.backup AND the per-tenant scripts/<tenant>/.env.backup files
# (the earlier literal `scripts/.env.backup` missed the per-tenant copies — PL-007).
# Example templates are re-included so they stay tracked.
.env*
!.env*.example
# Key / cert material the rotation & db_backup scripts may touch (PL-016)
*.pem
*.key
*.p12
*.pfx

# ── Script output ───────────────────────────────────────────────────────────────
# pg_dump output files produced by db_backup scripts
scripts/backups/

# ── Logs ────────────────────────────────────────────────────────────────────────
**/logs/

# ── IDE ─────────────────────────────────────────────────────────────────────────
.idea/
.vscode/

# ── E2E (Playwright / Node) ──────────────────────────────────────────────────────
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/playwright/.cache/
e2e/.last-run.json
# Self-contained-stack secrets generated per-run by ci_stack.py (RSA keypair,
# OIDC client creds, DB password) — never commit.
e2e/.e2e-ci.json

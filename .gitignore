# ── Python ─────────────────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/

# ── Virtual environments ────────────────────────────────────────────────────────
**/venv/
**/.venv/

# ── Secrets / local env files ───────────────────────────────────────────────────
# Real database credentials used by the backup scripts — never commit
scripts/.env.backup

# ── Script output ───────────────────────────────────────────────────────────────
# pg_dump output files produced by db_backup scripts
scripts/backups/

# ── Logs ────────────────────────────────────────────────────────────────────────
**/logs/

# ── IDE ─────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
